{
  "name": "corvus-x",
  "version": "1.0.0",
  "main": "./dist-electron/main.js",
  "scripts": {
    "clean": "rimraf dist dist-electron",
    "dev": "vite",
    "build": "npm run clean && tsc && tsc -p electron/tsconfig.json && vite build",
    "preview": "vite preview",
    "postinstall": "cross-env SHARP_IGNORE_GLOBAL_LIBVIPS=1 npm rebuild sharp",
    "electron:dev": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "electron:build": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=production electron .",
    "app:dev": "concurrently \"npm run dev -- --port 5180\" \"wait-on http://localhost:5180 && npm run electron:dev\"",
    "app:build": "npm run build && electron-builder",
    "build:win:installer": "npm run build && electron-builder --win nsis",
    "build:win:portable": "npm run build && electron-builder --win portable",
    "build:win:zip": "npm run build && electron-builder --win zip",
    "build:win": "npm run build && electron-builder --win nsis portable zip",
    "build:linux:deb": "npm run build && electron-builder --linux deb",
    "build:linux:appimage": "npm run build && electron-builder --linux AppImage",
    "build:linux:tar": "npm run build && electron-builder --linux tar.xz",
    "build:linux": "npm run build && electron-builder --linux deb AppImage tar.xz",
    "build:mac:dmg": "npm run build && electron-builder --mac dmg",
    "build:mac:zip": "npm run build && electron-builder --mac zip",
    "build:mac:dir": "npm run build && electron-builder --mac dir",
    "build:mac": "npm run build && electron-builder --mac dmg zip dir",
    "build:all": "npm run build && electron-builder --win nsis portable zip --linux deb AppImage tar.xz --mac dmg zip dir",
    "watch": "tsc -p electron/tsconfig.json --watch",
    "start": "npm run app:dev",
    "dist": "npm run app:build"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.electron.meeting-notes",
    "productName": "CorvusX Intelligence in the Shadows",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/mac/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/win/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/png/",
      "category": "Office",
      "maintainer": "Felix-au <harshit.soni.23cse@bmu.edu.in>"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "requestExecutionLevel": "user"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ibttf",
        "repo": "corvus-x-frontend"
      }
    ]
  },
  "keywords": [],
  "author": "Felix-au <harshit.soni.23cse@bmu.edu.in>",
  "license": "ISC",
  "description": "CorvusX: Intelligence in the Shadows",
  "devDependencies": {
    "@types/color": "^4.2.0",
    "@types/diff": "^6.0.0",
    "@types/electron": "^1.4.38",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/screenshot-desktop": "^1.12.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.5.10",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@google/genai": "^0.12.0",
    "@google/generative-ai": "^0.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.2",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.6",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-code-blocks": "^0.1.6",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "react-query": "^3.39.3",
    "react-syntax-highlighter": "^15.6.1",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.4",
    "tesseract.js": "^5.0.5",
    "uiohook-napi": "^1.5.5",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "prismjs": "^1.30.0",
    "shell-quote": "^1.8.4",
    "esbuild": "^0.25.0",
    "tar": "^7.5.11",
    "uuid": "^11.1.1",
    "joi": "^17.13.4",
    "@babel/core": "^7.29.1"
  }
}
